# Main mode: local PostgreSQL container with dump_rasp.sql.
DEMO_MODE=false
POSTGRES_DB=dump_rasp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional: override this only if you want to connect to pgAdmin/local university DB instead of Docker db.
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@host.docker.internal:5432/dump_rasp

# Optional UI preview without PostgreSQL.
# DEMO_MODE=true
# DATABASE_URL=
